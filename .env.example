# Veřejné (pro metadata / odkazy)
NEXT_PUBLIC_SITE_URL=https://krouzekumeleinteligence.cz

# Google Analytics 4 (gtag) — načte se až po souhlasu „Všechno ano!“ v cookie liště
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-PDZK8PWF7G

# Google Search Console — meta tag „google-site-verification“ (viz web/SEO_LAUNCH_CHECKLIST.md)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Výchozí v kódu je kurzy@aikonic.cz (stejné jako aikonic.cz)
NEXT_PUBLIC_CONTACT_EMAIL=kurzy@aikonic.cz

# Volitelně: odkazy na sociální profily (zobrazí se ikonky v patičce a na kontaktu)
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/...
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/...
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/...
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/...

# Volitelně: absolutní URL obrázku pro Open Graph / Twitter (1200×630)
# NEXT_PUBLIC_OG_IMAGE=/og.png

# Zobrazení na stránce platby (veřejné údaje pro rodiče)
NEXT_PUBLIC_BANK_ACCOUNT=7350622004/5500
NEXT_PUBLIC_BANK_IBAN=CZ4855000000007350622004

# Volitelně: URL webhooku (Make, Zapier, vlastní endpoint) — přihlášky jen sem (admin v tomto projektu je neuvidí).
# Nepoužívej současně se Supabase ukládáním přihlášek — webhook má přednost před DB.
# REGISTRATIONS_WEBHOOK_URL=https://...
# Stejný tajný řetězec na přijímací straně ověřte v hlavičce Authorization: Bearer …
# REGISTRATIONS_WEBHOOK_SECRET=

# Rate limiting (doporučeno v produkci) — nejdřív se použije Supabase, pokud je nastaveno:
# 1) Spusť SQL z web/supabase-rate-limit.sql v Supabase → SQL Editor
# 2) Termíny kurzu: web/supabase-course-runs.sql
# 3) Veřejné přihlášky (bez webhooku): web/supabase-registrations.sql — jinak na Vercelu nejde zapisovat do data/
# 4) Účty rodičů s heslem: web/supabase-parent-accounts.sql (magic odkaz funguje i bez této tabulky)
# 5) Project Settings → API → URL + service_role (NIKDY do frontendu, jen server / Vercel env)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Alternativa bez Supabase: Upstash Redis — https://upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Volitelně: když nemáš Supabase, lze termíny ukládat do Redis (jinak stačí Supabase + supabase-course-runs.sql).

# Bez výše uvedeného běží limit v paměti instance (vhodné jen pro lokální vývoj).

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile) — ochrana registrace před boty
# Obě proměnné nastav najednou: veřejný klíč do widgetu, secret jen na server (nikdy NEXT_PUBLIC u secret).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# Interní admin (seznam přihlášek, stavy, poznámky, termín) — /admin/login
# Silný náhodný řetězec (min. 16 znaků). Nikdy do frontendu / veřejného repa.
# ADMIN_SECRET=

# Přihlášení rodičů — /rodic/prihlaseni (magic odkaz + volitelné účty s heslem v data/parent-accounts.jsonl)
# PARENT_AUTH_SECRET=

# E-mail přes Resend (https://resend.com) — bez klíče se jen zaloguje do konzole serveru
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Kroužek AI <kurz@vas-domena.cz>
# Volitelně: interní notifikace o nové přihlášce (1+ adres, oddělené čárkou).
# Když není nastaveno, notifikace chodí na NEXT_PUBLIC_CONTACT_EMAIL.
# RESEND_INTERNAL_TO=kurzy@aikonic.cz,ops@aikonic.cz
